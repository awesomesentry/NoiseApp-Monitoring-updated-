# ============================================================
# Smart Classroom Noise Monitor - Server Environment
# ============================================================
#
# Copy this file to server/.env and fill in your credentials.
# NEVER commit server/.env to version control.
#

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated origins, or * for all (development only)
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Supabase (server-side only — never exposed to the browser)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Service role key for privileged operations (cleanup cron, admin bootstrap)
# Optional but recommended for delete_expired_noise_events RPC
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Optional: protect cleanup endpoint when called by external cron (without admin JWT)
# CLEANUP_API_KEY=your-random-secret-key
